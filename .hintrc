{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "scrollbar-width",
          "scrollbar-color",
          "scrollbar-color: oklch(0.75 0 0) transparent",
          "scrollbar-width: none"
        ]
      }
    ],
    "no-inline-styles": "off",
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "meta[name=theme-color]"
        ]
      }
    ],
    "apple-touch-icons": "off",
    "axe/aria": [
      "default",
      {
        "aria-valid-attr-value": "off",
        "aria-required-children": "off",
        "aria-required-parent": "off",
        "aria-required-attr": "off",
        "aria-allowed-attr": "off",
        "aria-roles": "off"
      }
    ],
    "typescript-config/is-valid": "off"
  }
}