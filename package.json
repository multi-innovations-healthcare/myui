{
  "name": "@multi_innovations_healthcare/myui",
  "private": false,
  "version": "0.1.21",
  "license": "MIT",
  "description": "MyUI is a library of components for building healthcare applications.",
  "keywords": [
    "react",
    "components",
    "ui",
    "library",
    "healthcare"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/multi-innovations-healthcare/myui.git"
  },
  "homepage": "https://myui.mih.co.th",
  "bugs": {
    "url": "https://github.com/multi-innovations-healthcare/myui/issues"
  },
  "main": "dist/myui.umd.js",
  "module": "dist/myui.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/myui.es.js",
      "require": "./dist/myui.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./src/styles.css"
  },
  "sideEffects": [
    "./dist/**/*.js",
    "./src/prelude.css",
    "./src/styles.css"
  ],
  "files": [
    "dist",
    "src/prelude.css",
    "src/styles.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:site": "tsc -b && cross-env VITE_BUILD_TARGET=site vite build",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "preview": "vite preview",
    "clean": "node -e \"try{require('fs').rmSync('dist',{recursive:true,force:true})}catch(e){}\"",
    "deploy:test": "bun run build:site && cross-env NODE_ENV=development bun run --watch ./deploy/index.ts",
    "deploy": "cross-env NODE_ENV=production bun run ./scripts/build-upload.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@iconify/tailwind4": "^1.2.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-google-maps/api": "^2.20.8",
    "@tailwindcss/vite": "^4.2.2",
    "ajv": "^8.18.0",
    "apexcharts": "^5.3.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.22",
    "hono": "^4.12.9",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "prism-react-renderer": "^2.4.1",
    "radix-ui": "^1.4.3",
    "react-apexcharts": "^1.8.0",
    "react-colorful": "^5.6.1",
    "react-leaflet": "^5.0.0",
    "react-number-format": "^5.4.4",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^2.10.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/dom-view-transitions": "^1.0.6",
    "@types/leaflet": "^1.9.15",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "bun-types": "^1.3.11",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
